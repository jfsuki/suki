  "scope": "global",
  "extends": [
    "framework/events/beg_anomaly_patterns.json"
  ],
  "compatibility": "backward_compatible",
  "status": "active",
  "fraud_patterns": [
    {
      "pattern_id": "duplicate_collection_signal",
      "description": "Multiple collection traces appear for the same settlement context without a valid split rationale.",
      "related_event_types": [
        "collection_event",
        "payment_event"
      ],
      "detection_type": "deterministic",
      "risk_weight": 0.86,
      "version": "1.0.0",
      "status": "active"
    },
    {
      "pattern_id": "refund_after_settled_collection",
      "description": "A refund is issued after a receivable has already been settled with no approved compensating chain.",
      "related_event_types": [
        "refund_event",
        "collection_event"
      ],
      "detection_type": "deterministic",
      "risk_weight": 0.91,
      "version": "1.0.0",
      "status": "active"
    }
  ],
  "data_quality_patterns": [
    {
      "pattern_id": "invoice_without_customer_reference",
      "description": "Commercial documents lose their customer anchor and degrade traceability.",
      "related_event_types": [
        "sale_event"
      ],
      "detection_type": "deterministic",
      "risk_weight": 0.68,
      "version": "1.0.0",
      "status": "active"
    },
    {
      "pattern_id": "orphan_master_data_reference",
      "description": "Operational events reference master data that is incomplete, stale or not governed.",
      "related_event_types": [
        "customer_creation",
        "purchase_event"
      ],
      "detection_type": "deterministic",
      "risk_weight": 0.55,
      "version": "1.0.0",
      "status": "active"
    }
  ],
  "beg_patterns": [
    {
      "pattern_id": "payment_without_invoice",
