      "related_event_types": [
        "payment_event"
      ],
      "detection_type": "beg_causal",
      "risk_weight": 0.93,
      "version": "1.0.0",
      "status": "active"
    },
    {
      "pattern_id": "collection_without_receivable",
      "description": "Collection event is present without a receivable context or related invoice.",
      "related_event_types": [
        "collection_event"
      ],
      "detection_type": "beg_causal",
      "risk_weight": 0.9,
      "version": "1.0.0",
      "status": "active"
    },
    {
      "pattern_id": "inventory_deduction_without_sale",
      "description": "Inventory reduction appears without a supporting sale or justified adjustment path.",
      "related_event_types": [
        "inventory_adjustment",
        "sale_event"
      ],
      "detection_type": "beg_causal",
      "risk_weight": 0.88,
      "version": "1.0.0",
      "status": "active"
    },
    {
      "pattern_id": "cross_tenant_link",
      "description": "Event payload references entities, documents, or parents outside the current tenant scope.",
      "related_event_types": [
        "sale_event",
        "payment_event",
        "collection_event",
        "alert_triggered"
      ],
      "detection_type": "beg_causal",
      "risk_weight": 1,
      "version": "1.0.0",
      "status": "active"
    }
  ],
  "behavioral_patterns": [
    {
      "pattern_id": "lead_stagnation_without_followup",
      "description": "Lead creation happens without timely operational follow-up activity.",
      "related_event_types": [
        "lead_created",
        "task_completed"
      ],
      "detection_type": "behavioral",
      "risk_weight": 0.61,
      "version": "1.0.0",
      "status": "active"
    },
    {
      "pattern_id": "revenue_drop_without_pipeline_shift",
