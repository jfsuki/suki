{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FiscalDocumentPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fiscal_document_id",
    "tenant_id",
    "document_type",
    "status",
    "header",
    "summary",
    "lines",
    "references",
    "metadata"
  ],
  "properties": {
    "fiscal_document_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": ["string", "null"] },
    "document_type": {
      "type": "string",
      "enum": [
        "sales_invoice",
        "support_document",
        "credit_note",
        "debit_note",
        "pos_ticket_fiscal_hook",
        "purchase_fiscal_hook"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "pending",
        "prepared",
        "submitted",
        "accepted",
        "rejected",
        "canceled"
      ]
    },
    "header": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_module",
        "source_entity_type",
        "source_entity_id"
      ],
      "properties": {
        "document_number": { "type": ["string", "null"] },
        "issue_date": { "type": ["string", "null"] },
        "currency": { "type": ["string", "null"] },
        "issuer_party_id": { "type": ["string", "null"] },
        "receiver_party_id": { "type": ["string", "null"] },
        "source_module": { "type": "string", "minLength": 1 },
        "source_entity_type": { "type": "string", "minLength": 1 },
        "source_entity_id": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subtotal", "tax_total", "total"],
      "properties": {
        "subtotal": { "type": ["number", "null"], "minimum": 0 },
        "tax_total": { "type": ["number", "null"], "minimum": 0 },
        "total": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["line_id", "description", "metadata"],
        "properties": {
          "line_id": { "type": "string", "minLength": 1 },
          "product_id": { "type": ["string", "null"] },
          "description": { "type": "string", "minLength": 1 },
          "qty": { "type": ["number", "null"], "exclusiveMinimum": 0 },
          "unit_amount": { "type": ["number", "null"], "minimum": 0 },
          "tax_rate": { "type": ["number", "null"], "minimum": 0 },
          "line_total": { "type": ["number", "null"], "minimum": 0 },
          "metadata": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "references": {
      "type": "object",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
