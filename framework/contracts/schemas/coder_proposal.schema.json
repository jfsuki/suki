{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_id": "coder_proposal",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "tenant_id",
    "project_id",
    "app_id",
    "run_id",
    "sprint_id",
    "ticket_id",
    "proposal_id",
    "coder_id",
    "summary",
    "target_files",
    "change_strategy",
    "risks",
    "requires_review",
    "result_status",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "coder_proposal"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "sprint_id": {
      "type": "string",
      "minLength": 1
    },
    "ticket_id": {
      "type": "string",
      "minLength": 1
    },
    "proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "coder_id": {
      "type": "string",
      "enum": ["Coder_OpenAI", "Coder_Gemini"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "target_files": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "change_strategy": {
      "type": "string",
      "minLength": 1
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requires_review": {
      "type": "boolean"
    },
    "result_status": {
      "type": "string",
      "enum": ["proposed", "superseded", "rejected", "accepted"]
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
