{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SUKI Control Tower Incident",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "incident_id",
    "tenant_id",
    "project_id",
    "app_id",
    "severity",
    "source",
    "related_task_id",
    "related_events",
    "status",
    "created_at"
  ],
  "properties": {
    "incident_id": {
      "type": "string",
      "minLength": 6
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warning", "critical"]
    },
    "source": {
      "type": "string",
      "enum": ["audit", "system", "user"]
    },
    "related_task_id": {
      "type": "string",
      "minLength": 1
    },
    "related_events": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": ["open", "investigating", "resolved"]
    },
    "description": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
