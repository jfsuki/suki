{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EntitySearchResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_type",
    "entity_id",
    "label",
    "subtitle",
    "score",
    "source_module",
    "matched_by",
    "metadata_json"
  ],
  "properties": {
    "entity_type": {
      "type": "string",
      "enum": ["product", "sale", "purchase", "invoice", "customer", "supplier", "order", "media_file"]
    },
    "entity_id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "subtitle": {
      "type": "string"
    },
    "score": {
      "type": "number"
    },
    "source_module": {
      "type": "string",
      "minLength": 1
    },
    "matched_by": {
      "type": "string",
      "minLength": 1
    },
    "metadata_json": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
