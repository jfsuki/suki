{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "POSReturn",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "tenant_id",
    "sale_id",
    "return_number",
    "status",
    "subtotal",
    "tax_total",
    "total",
    "metadata",
    "lines"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": ["string", "null"]
    },
    "sale_id": {
      "type": "string",
      "minLength": 1
    },
    "return_number": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["completed", "voided"]
    },
    "subtotal": {
      "type": "number",
      "minimum": 0
    },
    "tax_total": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "total": {
      "type": "number",
      "minimum": 0
    },
    "reason": {
      "type": ["string", "null"]
    },
    "created_by_user_id": {
      "type": ["string", "null"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "lines": {
      "type": "array",
      "items": {
        "$ref": "pos_return_line.schema.json"
      }
    }
  }
}
