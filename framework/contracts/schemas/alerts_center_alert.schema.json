{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Alerts Center Alert",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenant_id",
    "alert_type",
    "title",
    "message",
    "severity",
    "source_type",
    "status",
    "created_at",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": ["string", "integer"]
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": ["string", "null"]
    },
    "alert_type": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "source_ref": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "acknowledged", "resolved", "dismissed"]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "due_at": {
      "type": ["string", "null"]
    },
    "metadata": {
      "type": "object"
    }
  }
}
