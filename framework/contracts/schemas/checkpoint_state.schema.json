{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_id": "checkpoint_state",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "tenant_id",
    "project_id",
    "app_id",
    "run_id",
    "sprint_id",
    "checkpoint_id",
    "stage",
    "status",
    "resume_token",
    "state_payload",
    "decision_trace",
    "artifacts",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "checkpoint_state"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "sprint_id": {
      "type": "string",
      "minLength": 1
    },
    "ticket_id": {
      "type": "string"
    },
    "checkpoint_id": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["created", "paused", "resumed", "completed", "failed"]
    },
    "resume_token": {
      "type": "string",
      "minLength": 1
    },
    "state_payload": {
      "type": "object"
    },
    "decision_trace": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
