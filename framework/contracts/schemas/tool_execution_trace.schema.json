{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_id": "tool_execution_trace",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenant_id",
    "module_key",
    "action_key",
    "input_schema_valid",
    "permission_check",
    "plan_check",
    "execution_latency",
    "success",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string"
    },
    "module_key": {
      "type": "string",
      "minLength": 1
    },
    "action_key": {
      "type": "string",
      "minLength": 1
    },
    "input_schema_valid": {
      "type": "boolean"
    },
    "permission_check": {
      "type": "string",
      "minLength": 1
    },
    "plan_check": {
      "type": "string",
      "minLength": 1
    },
    "execution_latency": {
      "type": "integer",
      "minimum": 0
    },
    "success": {
      "type": "boolean"
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "type": "object"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
