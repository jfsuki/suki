{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Alerts Center Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenant_id",
    "task_type",
    "title",
    "description",
    "priority",
    "status",
    "created_at",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": ["string", "integer"]
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": ["string", "null"]
    },
    "task_type": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "assigned_to": {
      "type": ["string", "null"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "completed", "cancelled"]
    },
    "due_at": {
      "type": ["string", "null"]
    },
    "related_entity_type": {
      "type": ["string", "null"]
    },
    "related_entity_id": {
      "type": ["string", "null"]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object"
    }
  }
}
