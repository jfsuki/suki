{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EcommerceStoreSetup",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenant_id",
    "store_id",
    "platform",
    "adapter_key",
    "status",
    "connection_status",
    "validation_result",
    "ready",
    "credentials_configured",
    "capabilities",
    "checks",
    "hooks"
  ],
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": ["string", "null"] },
    "store_id": { "type": "string", "minLength": 1 },
    "platform": {
      "type": "string",
      "enum": ["woocommerce", "tiendanube", "prestashop", "custom_store", "unknown"]
    },
    "adapter_key": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "disconnected"]
    },
    "connection_status": {
      "type": "string",
      "enum": ["not_configured", "pending_validation", "validated", "failed"]
    },
    "validation_result": { "type": "string", "minLength": 1 },
    "ready": { "type": "boolean" },
    "credentials_configured": { "type": "boolean" },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "products_read",
        "products_write",
        "orders_read",
        "orders_write",
        "inventory_sync",
        "webhooks",
        "customers_read"
      ],
      "properties": {
        "products_read": { "type": "boolean" },
        "products_write": { "type": "boolean" },
        "orders_read": { "type": "boolean" },
        "orders_write": { "type": "boolean" },
        "inventory_sync": { "type": "boolean" },
        "webhooks": { "type": "boolean" },
        "customers_read": { "type": "boolean" }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "store_exists",
        "platform_supported",
        "store_active",
        "connection_validated",
        "credentials_configured"
      ],
      "properties": {
        "store_exists": { "type": "boolean" },
        "platform_supported": { "type": "boolean" },
        "store_active": { "type": "boolean" },
        "connection_validated": { "type": "boolean" },
        "credentials_configured": { "type": "boolean" }
      }
    },
    "hooks": { "type": "object", "additionalProperties": true }
  }
}
