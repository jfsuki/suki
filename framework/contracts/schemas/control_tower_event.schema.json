{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SUKI Control Tower Feed Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "tenant_id",
    "project_id",
    "app_id",
    "timestamp",
    "source",
    "linked_ids",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 6
    },
    "event_type": {
      "type": "string",
      "enum": ["task_update", "audit_alert", "incident_created", "system_warning"]
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": ["chat", "system", "audit", "user"]
    },
    "linked_ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "type": "string"
        },
        "conversation_id": {
          "type": "string"
        },
        "incident_id": {
          "type": "string"
        },
        "beg_event_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
