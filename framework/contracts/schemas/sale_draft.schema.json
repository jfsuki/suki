{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SaleDraft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "tenant_id",
    "status",
    "subtotal",
    "tax_total",
    "total",
    "metadata",
    "lines"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": ["string", "null"]
    },
    "session_id": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "ready", "checked_out", "cancelled"]
    },
    "customer_id": {
      "type": ["string", "null"]
    },
    "currency": {
      "type": ["string", "null"]
    },
    "subtotal": {
      "type": "number",
      "minimum": 0
    },
    "tax_total": {
      "type": "number",
      "minimum": 0
    },
    "total": {
      "type": "number",
      "minimum": 0
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "lines": {
      "type": "array",
      "items": {
        "$ref": "sale_draft_line.schema.json"
      }
    }
  }
}
