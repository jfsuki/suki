{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "POSSession",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "tenant_id",
    "status",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": ["string", "null"]
    },
    "store_id": {
      "type": ["string", "null"]
    },
    "cash_register_id": {
      "type": ["string", "null"]
    },
    "opened_by_user_id": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed", "draft", "paused"]
    },
    "opened_at": {
      "type": ["string", "null"]
    },
    "closed_at": {
      "type": ["string", "null"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
