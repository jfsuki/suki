{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_id": "sprint_decision",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "tenant_id",
    "project_id",
    "app_id",
    "run_id",
    "sprint_id",
    "decision_id",
    "status",
    "rationale",
    "blocking_items",
    "next_steps",
    "decided_at"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "sprint_decision"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "sprint_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["CLOSED", "CONTINUE", "BLOCKED", "NEEDS_REVIEW"]
    },
    "rationale": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocking_items": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decided_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
