{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AppManifestContract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "app", "db", "registry"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{1,62}$"
        },
        "name": { "type": "string", "minLength": 2, "maxLength": 120 },
        "description": { "type": "string", "maxLength": 500 },
        "status": { "type": "string", "enum": ["draft", "active", "archived"] },
        "tenant_mode": { "type": "string", "enum": ["shared", "isolated"] },
        "default_locale": { "type": "string" },
        "timezone": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "db": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "schema_source"],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["shared_schema", "dedicated_db"]
        },
        "schema_source": {
          "type": "string",
          "enum": ["master", "custom"]
        },
        "master_schema_id": { "type": "string", "minLength": 1 },
        "connection_alias": { "type": "string", "minLength": 1 },
        "database_name": { "type": "string", "minLength": 1 },
        "provision": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "create_on_first_run": { "type": "boolean" },
            "db_name_prefix": { "type": "string", "minLength": 1 },
            "migrations": { "type": "string", "enum": ["auto", "manual", "off"] }
          }
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "track_changes": { "type": "boolean" },
        "track_routes": { "type": "boolean" },
        "track_config": { "type": "boolean" },
        "track_db_profile": { "type": "boolean" },
        "track_integrations": { "type": "boolean" },
        "track_processes": { "type": "boolean" }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "login_field": { "type": "string", "enum": ["username", "email"] },
        "email_optional": { "type": "boolean" },
        "mfa": { "type": "string", "enum": ["off", "optional", "required"] },
        "roles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "default_role": { "type": "string" },
        "password_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min_length": { "type": "integer", "minimum": 6 },
            "require_numbers": { "type": "boolean" },
            "require_symbols": { "type": "boolean" }
          }
        }
      }
    },
    "integrations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "provider"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{1,62}$"
          },
          "type": {
            "type": "string",
            "enum": ["e-invoicing", "payments", "erp", "crm", "custom"]
          },
          "provider": { "type": "string" },
          "base_url": { "type": "string" },
          "enabled": { "type": "boolean" },
          "auth": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["api_key", "oauth2", "basic", "jwt", "custom"]
              },
              "ref": { "type": "string" },
              "header": { "type": "string" },
              "token_param": { "type": "string" }
            }
          },
          "webhooks": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "processes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "actions"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{1,62}$"
          },
          "label": { "type": "string" },
          "ui_form": { "type": "string" },
          "intents": {
            "type": "array",
            "items": { "type": "string" }
          },
          "requires": {
            "type": "array",
            "items": { "type": "string" }
          },
          "actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "permissions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "async": { "type": "boolean" },
          "confirm": { "type": "boolean" },
          "integration_ref": { "type": "string" }
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "db": {
            "properties": {
              "schema_source": { "const": "master" }
            },
            "required": ["schema_source"]
          }
        }
      },
      "then": {
        "properties": {
          "db": {
            "required": ["master_schema_id"]
          }
        }
      }
    }
  ]
}
