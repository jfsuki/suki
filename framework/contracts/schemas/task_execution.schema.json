{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SUKI Task Execution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "tenant_id",
    "project_id",
    "app_id",
    "conversation_id",
    "intent",
    "status",
    "source",
    "related_entities",
    "related_events",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 6
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "message_id": {
      "type": "string"
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed"]
    },
    "source": {
      "type": "string",
      "enum": ["chat", "system", "audit"]
    },
    "route_path": {
      "type": "string"
    },
    "gate_decision": {
      "type": "string",
      "enum": ["allow", "warn", "blocked", "off", "unknown"]
    },
    "related_entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "entity_type": {
            "type": "string"
          },
          "entity_id": {
            "type": "string"
          },
          "tenant_id": {
            "type": "string"
          },
          "app_id": {
            "type": "string"
          }
        }
      }
    },
    "related_events": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "execution_result": {
      "type": "object",
      "additionalProperties": true
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
