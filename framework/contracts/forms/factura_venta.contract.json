{
    "id": "factura_venta",
    "name": "Factura de Venta Electrónica",
    "version": "1.0.0",
    "entity": "ventas",
    "title": "Factura de Venta",
    "fields": [
        {
            "id": "numero",
            "name": "numero",
            "type": "string",
