{
    "meta": {
        "name": "domain_playbooks",
        "version": "0.3.6",
        "updated_at": "2026-02-20",
        "goal": "Universal business playbooks to create ERP/CRM/accounting and operational mini-apps by conversation.",
        "notes": [
            "Operational guidance only. Legal decisions require accountant validation.",
            "Builder asks one minimal question at a time.",
            "Agent must validate real entities/forms from registry before promising actions.",
            "Coverage expanded for ERP, CRM, accounting, medical, church, commerce and SAP-side mini-apps.",
            "v0.3.6: +perfil spa_bienestar y aliases de estetica/spa para onboarding."
        ]
    },
    "discovery": {
        "questions": [
            "Que tipo de negocio tienes?",
            "Vendes productos, servicios o ambos?",
            "Tus ventas son de contado, credito o mixtas?",
            "Necesitas inventario?",
            "Que reportes quieres primero: ventas, cartera, gastos o utilidad?"
        ],
        "minimum_profile_fields": [
            "business_type",
            "operation_model",
            "billing_need",
            "inventory_need"
        ]
    },
