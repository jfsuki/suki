    "assistant_rules": {
        "never_emit_real_invoice_without_provider_config": true,
        "never_confirm_sent_to_tax_authority_if_no_provider_response": true,
        "always_store_provider_id_and_status": true,
        "always_log_audit_event": true,
        "always_explain_missing_data_in_plain_language": true,
        "always_use_registry_before_replying_available_actions": true
    },
