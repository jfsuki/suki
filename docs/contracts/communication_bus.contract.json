{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Suki Inter-Agent Communication Bus Contract",
  "description": "Standardizes events exchanged between specialized agents.",
  "type": "object",
  "required": ["event_id", "type", "source_agent_id", "payload", "timestamp"],
  "properties": {
    "event_id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "ENTITY_CREATED",
        "STOCK_RESERVED",
        "PAYMENT_CONFIRMED",
        "KNOWLEDGE_GAP_DETECTED",
        "VALIDATION_REQUESTED",
        "ACTION_REJECTED",
        "HUMAN_APPROVAL_PENDING"
      ]
    },
    "source_agent_id": { "type": "string" },
    "target_agent_id": { "type": "string", "description": "Optional: Specific agent target (null for broadcast)." },
    "payload": {
      "type": "object",
      "description": "The actual data associated with the event."
    },
    "trace": {
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "project_id": { "type": "string" },
        "original_session_id": { "type": "string" }
      }
    },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
