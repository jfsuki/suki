{
  "contract_id": "agentops_metrics_contract",
  "version": "1.4.6",
  "effective_date": "2026-03-13",
  "addenda_of": null,
  "status": "canonical_draft",
  "contract_location": "docs/contracts",
  "scope": "AgentOps observability and KPI contract without runtime implementation",
  "traceable_events_minimum": [
    "router.decision",
    "gate.evaluation",
    "intent.classified",
    "action.classified",
    "action.executed",
    "response.emitted",
    "cost.recorded",
    "hallucination.flagged"
  ],
  "required_event_fields": [
    "event_name",
    "event_time",
    "tenant_id",
    "project_id",
    "session_id",
    "message_id",
    "route_path",
    "gate_decision",
    "supervisor_status",
    "supervisor_score",
    "supervisor_flags",
    "supervisor_reasons",
    "needs_regression_case",
    "needs_memory_hygiene",
    "module_used",
    "access_control_action",
    "saas_plan_action",
    "skill_group",
    "alert_action",
    "task_action",
    "reminder_action",
    "pending_items_count",
    "store_id",
    "platform",
