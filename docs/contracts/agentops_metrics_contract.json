    "versions",
    "latency_ms"
  ],
  "runtime_trace_minimum_fields": [
    "route_reason",
    "semantic_enabled",
    "rag_attempted",
    "rag_used",
    "rag_result_count",
    "evidence_gate_status",
    "fallback_reason",
    "llm_used",
    "skill_detected",
    "skill_selected",
    "skill_executed",
    "skill_failed",
    "skill_execution_ms",
    "skill_result_status",
    "skill_fallback_reason",
    "tool_calls_count",
    "retry_count",
    "llm_fallback_count",
    "loop_guard_triggered",
    "same_route_repeat_count",
    "request_mode",
    "module_used",
    "access_control_action",
    "saas_plan_action",
    "skill_group",
    "alert_action",
    "task_action",
    "reminder_action",
    "pending_items_count",
    "store_id",
    "platform",
    "adapter_key",
    "validation_result",
    "link_id",
    "external_order_id",
    "local_reference_type",
    "local_reference_id",
    "local_product_id",
    "external_product_id",
    "sync_status",
    "sync_direction",
    "target_user_id",
    "actor_user_id",
    "role_key",
    "permission_checked",
    "decision",
    "plan_key",
    "limit_key",
    "ambiguity_detected",
    "metrics_delta",
    "supervisor"
  ],
  "metrics_delta_fields": [
    "requests_total",
    "routed_by_rules",
    "routed_by_rag",
    "routed_by_llm",
    "evidence_gate_failures",
    "rag_errors",
    "loop_guard_hits",
    "semantic_disabled_requests",
    "llm_fallback_requests",
    "tenant_scope_violations_detected",
    "rag_result_count_total"
  ],
  "versions_contract": {
    "required": true,
    "fields": [
      "prompt_version",
      "router_policy_version",
      "action_catalog_version",
      "skills_catalog_version",
      "akp_version",
      "policy_pack_version"
    ]
  },
  "metrics": {
    "json_valid_pct": {
      "description": "Percentage of structured responses that are valid JSON.",
      "formula": "valid_json_responses / total_structured_responses",
      "target_direction": "higher_is_better",
      "unit": "ratio"
    },
    "akp_correct_pct": {
      "description": "Percentage of RAG-required responses with correct AKP evidence usage.",
      "formula": "responses_with_valid_akp_references / rag_required_responses",
      "target_direction": "higher_is_better",
      "unit": "ratio"
    },
    "fallback_rate": {
      "description": "Share of requests resolved via LLM stage.",
      "formula": "llm_resolutions / total_resolutions",
      "target_direction": "lower_is_better",
      "unit": "ratio"
    },
    "hallucination_flags_rate": {
      "description": "Share of responses flagged as hallucination during audit.",
      "formula": "hallucination_flagged_responses / audited_responses",
      "target_direction": "lower_is_better",
      "unit": "ratio"
    },
    "cost_per_conversation": {
      "description": "Average total cost per completed conversation.",
      "formula": "sum(conversation_cost) / total_conversations",
      "target_direction": "lower_is_better",
      "unit": "currency"
    },
    "latency": {
      "description": "Latency indicators per routing and response path.",
      "formula": "aggregate(latency_ms)",
      "target_direction": "lower_is_better",
      "unit": "ms",
      "required_aggregates": [
        "p50",
        "p95",
        "p99"
      ]
    }
  },
  "metric_aliases_required": [
    "%json_valid",
    "%akp_correct",
    "fallback_rate",
    "hallucination_flags_rate",
    "cost_per_conversation",
    "latency"
  ],
  "supervisor_flag_catalog": [
    "insufficient_evidence",
    "rag_weak_result",
    "skill_execution_failed",
    "policy_route_mismatch",
    "fallback_overuse",
    "possible_hallucination",
    "weak_safe_fallback"
  ]
}
