<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- 1. Bloquear acceso directo a archivos .php (secreto operacional) -->
                <rule name="BlockDirectPhpAccess" stopProcessing="true">
                    <match url="\.php$" />
                    <conditions>
                        <add input="{REQUEST_URI}" pattern="/index\.php$" negate="true" />
                    </conditions>
                    <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Direct access to PHP files is denied." />
                </rule>

                <!-- 2. Bloquear carpetas sensibles (Hidden Layer) -->
                <rule name="BlockSensitiveDirs" stopProcessing="true">
                    <match url="^(docs|brain|\.agent|\.suki|storage|vendor|framework/(app|config|contracts|database|models|scripts|views)|project/(config|contracts|database|models|views)|tower/views)" />
                    <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access to system directories is denied." />
                </rule>

                <!-- 3. Enrutamiento Enmascarado (Los 4 Mundos) -->
                
                <!-- Marketplace -->
                <rule name="RouteMarketplace" stopProcessing="true">
                    <match url="^marketplace(/.*)?$" />
                    <action type="Rewrite" url="framework/public/index.php?url={R:1}" appendQueryString="true" />
                </rule>

                <!-- Apps -->
                <rule name="RouteApps" stopProcessing="true">
                    <match url="^apps(/.*)?$" />
                    <action type="Rewrite" url="project/public/index.php?url={R:1}" appendQueryString="true" />
                </rule>

                <!-- Torre de Control -->
                <rule name="RouteTorre" stopProcessing="true">
                    <match url="^torre(/.*)?$" />
                    <action type="Rewrite" url="tower/public/index.php?url={R:1}" appendQueryString="true" />
                </rule>

                <!-- Builder Alias -->
                <rule name="RouteBuilder" stopProcessing="true">
                    <match url="^builder(/.*)?$" />
                    <action type="Rewrite" url="project/public/index.php?url=builder" appendQueryString="true" />
                </rule>

                <!-- Redirección por defecto al Marketplace -->
                <rule name="DefaultRedirect" stopProcessing="true">
                    <match url="^$" />
                    <action type="Redirect" url="marketplace/" redirectType="Found" />
                </rule>
            </rules>
        </rewrite>

        <!-- 4. Páginas de Error Personalizadas estilo SUKI -->
        <!-- NOTA: El path debe ser relativo a la raíz configurada en IIS -->
        <httpErrors errorMode="Custom" existingResponse="Replace">
            <remove statusCode="404" />
            <error statusCode="404" path="/suki/framework/views/errors/suki_error.php?code=404" responseMode="ExecuteURL" />
            <remove statusCode="403" />
            <error statusCode="403" path="/suki/framework/views/errors/suki_error.php?code=403" responseMode="ExecuteURL" />
            <remove statusCode="500" />
            <error statusCode="500" path="/suki/framework/views/errors/suki_error.php?code=500" responseMode="ExecuteURL" />
        </httpErrors>

        <security>
            <requestFiltering>
                <hiddenSegments>
                    <add segment=".agent" />
                    <add segment=".suki" />
                    <add segment="vendor" />
                </hiddenSegments>
            </requestFiltering>
        </security>
        
        <staticContent>
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
        </staticContent>
    </system.webServer>
</configuration>
