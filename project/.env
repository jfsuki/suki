CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-latest
CLAUDE_BASE_URL=https://api.anthropic.com/v1/messages

# LLM policy staging (primary/secondary + quotas)
LLM_SMOKE_PRIMARY=gemini
LLM_SMOKE_MODE=gemini
LLM_SMOKE_MAX_TOKENS=320
LLM_GEMINI_SMOKE_CHECK_FALLBACK=1
LLM_SESSION_QUOTA_ENABLED=1
LLM_MAX_REQUESTS_PER_SESSION=120
LLM_SESSION_QUOTA_WINDOW_SECONDS=86400
LLM_MAX_REQUESTS_PER_MINUTE=0
LLM_MAX_REQUESTS_PER_MINUTE_OPENROUTER=90
LLM_MAX_REQUESTS_PER_MINUTE_GEMINI=20
