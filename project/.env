DB_HOST=localhost
DB_NAME=suki_saas
DB_USER=root
DB_PASS=
APP_URL=http://suki.test:8080
# Opcional: ruta del framework si no está como ../framework
SUKI_FRAMEWORK_ROOT=
# Opcional: URL pública del framework (assets/editor)
SUKI_FRAMEWORK_PUBLIC_URL=
DB_DRIVER=mysql
DB_PORT=3306
DB_CHARSET=utf8mb4
# Aisla tablas fisicas por proyecto (p_<hash>__tabla) en DB compartida
DB_NAMESPACE_BY_PROJECT=1
# Guardrail anti-colapso (0 = sin limite)
DB_MAX_TABLES_PER_PROJECT=120
# DB_PATH= (solo sqlite)
# TENANT_ID=

# AI Providers (opcional)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions
GEMINI_API_KEY=AIzaSyBC1klmhID4alBF6croPOpx4jRpqovMX98
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_ROUTER_MODE=gemini

# Optional providers
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=qwen/qwen3-coder-next
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_REFERER=http://localhost
