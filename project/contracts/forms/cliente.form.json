{
  "type": "form",
  "name": "cliente.form",
  "version": "1.0.0",
  "mode": "create",

  "layout": {
    "type": "sections",
    "columns": 2,
    "gap": "4",
    "sections": [
      {
        "id": "datos_basicos",
        "title": "Datos del cliente",
        "description": "Información principal del cliente",
        "columns": 2,
        "fields": ["nombre", "email", "telefono"]
      },
      {
        "id": "ubicacion",
        "title": "Ubicación",
        "description": "Datos geográficos",
        "columns": 3,
        "fields": ["pais", "ciudad", "direccion"]
      },
      {
        "id": "estado",
        "title": "Configuración",
        "columns": 2,
        "fields": ["activo", "tipo_cliente"]
      }
    ]
  },

  "fields": [
    {
      "id": "nombre",
      "name": "nombre",
      "type": "text",
      "label": "Nombre completo",
      "required": true
    },
    {
      "id": "email",
      "name": "email",
      "type": "email",
      "label": "Correo electrónico"
    },
    {
      "id": "telefono",
      "name": "telefono",
      "type": "text",
      "label": "Teléfono"
    },
    {
      "id": "pais",
      "name": "pais",
      "type": "select",
      "label": "País",
      "options": [
        { "value": "CO", "label": "Colombia" },
        { "value": "MX", "label": "México" }
      ]
    },
    {
      "id": "ciudad",
      "name": "ciudad",
      "type": "select",
      "label": "Ciudad",
      "options": {
        "dependsOn": "pais",
        "source": "api",
        "endpoint": "/api/ciudades",
        "map": {
          "value": "id",
          "label": "nombre"
        }
      }
    },
    {
      "id": "direccion",
      "name": "direccion",
      "type": "textarea",
      "label": "Dirección"
    },
    {
      "id": "activo",
      "name": "activo",
      "type": "checkbox",
      "label": "Cliente activo",
      "defaultValue": true
    },
    {
      "id": "tipo_cliente",
      "name": "tipo_cliente",
      "type": "select",
      "label": "Tipo de cliente",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "vip", "label": "VIP" }
      ]
    }
  ],

  "grids": [
    {
      "type": "grid",
      "name": "cliente_contactos",
      "mode": "create",

      "columns": [
        {
          "name": "nombre",
          "label": "Nombre",
          "input": {
            "type": "text",
            "editable": true
          }
        },
        {
          "name": "cargo",
          "label": "Cargo",
          "input": {
            "type": "text",
            "editable": true
          }
        },
        {
          "name": "telefono",
          "label": "Teléfono",
          "input": {
            "type": "text",
            "editable": true
          }
        },
        {
          "name": "email",
          "label": "Email",
          "input": {
            "type": "email",
            "editable": true
          },
          "validation": {
              "required": true,
              "pattern": "^[\\w-\\.]+@([\\w-]+\\.)+[\\w-]{2,4}$",
              "maxlength": 100,
              "sanitize": "email",
              "message": "Email no válido"
            }
        }
      ]
    },

    {
      "type": "grid",
      "name": "cliente_facturacion",
      "mode": "create",

      "columns": [
        {
          "name": "concepto",
          "label": "Concepto",
          "input": {
            "type": "text"
          }
        },
        {
          "name": "cantidad",
          "label": "Cantidad",
          "input": {
            "type": "number"
          }
        },
        {
          "name": "valor_unitario",
          "label": "Valor Unitario",
          "input": {
            "type": "number"
          }
        },
        {
          "name": "subtotal",
          "label": "Subtotal",
          "formula": {
            "expression": "cantidad * valor_unitario",
            "watch": ["cantidad", "valor_unitario"]
          },
          "total": {
            "type": "sum",
            "label": "Total Facturación"
          }
        }
      ]
    }
    
  ],
  "summary": [
  {
    "name": "total_cantidad",
    "label": "Total Cantidad",
    "type": "sum",
    "source": {
      "grid": "cliente_facturacion",
      "field": "cantidad"
    }
  },
  {
    "name": "subtotal_general",
    "label": "Subtotal",
    "type": "sum",
    "source": {
      "grid": "cliente_facturacion",
      "field": "subtotal"
    }
  },
  {
    "name": "iva",
    "label": "IVA (19%)",
    "type": "formula",
    "expression": "subtotal_general * 0.19",
    "watch": ["subtotal_general"]
  },
  {
    "name": "total_general",
    "label": "Total a Pagar",
    "type": "formula",
    "expression": "subtotal_general + iva",
    "watch": ["subtotal_general", "iva"]
  }
]

}
