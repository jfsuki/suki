            ],
            "version": "1.0.0",
            "vectorize": true
        },
        {
            "id": "ks_ferreteria_002",
            "sector": "FERRETERIA_MINORISTA",
            "title": "Control de items y unidades en mostrador",
            "facts": [
                "Cada item facturado debe incluir descripcion comercial y valor unitario para evitar ambiguedad en caja.",
                "Las ventas de ferreteria suelen mezclar unidades, paquetes o metros y deben quedar claras en la factura."
            ],
            "source_refs": [
                "playbook:FERRETERIA_MINORISTA",
                "rule:ITEM_CLARITY_FOR_SALES"
            ],
            "tags": [
                "items",
