                "calidad_dato"
            ],
            "version": "1.0.0",
            "vectorize": true
        },
        {
            "id": "ks_ferreteria_003",
            "sector": "FERRETERIA_MINORISTA",
            "title": "Validacion operativa previa al cierre de venta",
            "facts": [
                "Antes de cerrar una venta se valida que el cliente exista y que el total sea numerico y positivo.",
                "Si falta un dato critico se debe pedir una sola pregunta de seguimiento y no ejecutar con supuestos."
            ],
            "source_refs": [
                "policy:ONE_QUESTION_MINIMAL",
                "policy:EXECUTION_GATES"
            ],
            "tags": [
                "gates",
                "validacion",
                "operacion"
            ],
            "version": "1.0.0",
            "vectorize": true
        }
    ],
    "support_faq": [
        {
            "id": "faq_ferreteria_001",
            "question": "Que hago si no recuerdo el cliente al momento de facturar?",
            "answer": "Solicita primero el nombre o documento del cliente y no ejecutes la factura hasta completar ese dato.",
            "tags": [
                "cliente",
                "factura"
            ],
            "version": "1.0.0",
            "vectorize": true
        },
        {
            "id": "faq_ferreteria_002",
            "question": "Como registro una venta con varios productos en una sola factura?",
            "answer": "Incluye todos los items con su descripcion y valor unitario, luego confirma el total acumulado antes de guardar.",
            "tags": [
                "items",
                "multi_item"
            ],
            "version": "1.0.0",
            "vectorize": true
        },
        {
            "id": "faq_ferreteria_003",
            "question": "Cuando debo marcar una venta como credito?",
            "answer": "Marca credito cuando el pago no se realiza completo en caja y registra una condicion de pago clara.",
            "tags": [
                "credito",
                "cartera"
            ],
            "version": "1.0.0",
            "vectorize": true
        },
        {
            "id": "faq_ferreteria_004",
            "question": "Que pasa si falta el total en la solicitud de factura?",
            "answer": "El asistente debe preguntar solo por el total faltante y bloquear la ejecucion hasta recibir ese valor.",
            "tags": [
                "slots",
                "one_question_policy"
            ],
            "version": "1.0.0",
            "vectorize": true
        }
    ],
