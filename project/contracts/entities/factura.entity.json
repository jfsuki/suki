{
  "type": "entity",
  "name": "factura",
  "label": "Factura",
  "version": "1.0",
  "table": {
    "name": "facturas",
    "primaryKey": "id",
    "timestamps": true,
    "softDelete": false,
    "tenantScoped": true
  },
  "fields": [
    { "name": "id", "type": "int", "primary": true, "source": "system" },
    { "name": "nombre", "type": "string", "label": "Nombre", "required": true, "source": "form" },
    { "name": "email", "type": "string", "label": "Email", "required": false, "source": "form" },
    { "name": "telefono", "type": "string", "label": "Telefono", "required": false, "source": "form" },
    { "name": "nit", "type": "string", "label": "NIT", "required": false, "source": "form" },
    { "name": "pais", "type": "string", "label": "Pais", "required": false, "source": "form" },
    { "name": "ciudad", "type": "string", "label": "Ciudad", "required": false, "source": "form" },
    { "name": "direccion", "type": "string", "label": "Direccion", "required": false, "source": "form" },
    { "name": "activo", "type": "bool", "label": "Activo", "required": false, "source": "form" },
    { "name": "tipo_cliente", "type": "string", "label": "Tipo cliente", "required": false, "source": "form" },

    { "name": "concepto", "type": "string", "label": "Concepto", "source": "grid:detalle_factura", "grid": "detalle_factura" },
    { "name": "cantidad", "type": "number", "label": "Cantidad", "source": "grid:detalle_factura", "grid": "detalle_factura" },
    { "name": "valor_unitario", "type": "decimal", "label": "Valor unitario", "source": "grid:detalle_factura", "grid": "detalle_factura" },
    { "name": "subtotal", "type": "decimal", "label": "Subtotal", "source": "grid:detalle_factura", "grid": "detalle_factura" },
    { "name": "porc_iva", "type": "number", "label": "IVA %", "source": "grid:detalle_factura", "grid": "detalle_factura" },
    { "name": "iva_prod", "type": "decimal", "label": "IVA", "source": "grid:detalle_factura", "grid": "detalle_factura" }
  ],
  "grids": [
    {
      "name": "detalle_factura",
      "table": "facturas__detalle_factura",
      "relation": {
        "type": "hasMany",
        "fk": "factura_id"
      }
    }
  ],
  "relations": [],
  "rules": [],
  "permissions": {
    "read": ["admin"],
    "create": ["admin"],
    "update": ["admin"],
    "delete": ["admin"]
  }
}
