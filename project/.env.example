# SUKI environment template
# Copy this file to project/.env and fill values for your environment.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# Core app/runtime
# -----------------------------------------------------------------------------
APP_URL=http://localhost
APP_ENV=dev
DEFAULT_ROLE=admin
PROJECT_ID=default
TENANT_ID=default
TENANT_KEY=
PROJECT_STORAGE_MODEL=
DB_STORAGE_MODEL=legacy
DB_CANONICAL_NEW_PROJECTS=0
DB_NAMESPACE_BY_PROJECT=1
DB_MAX_TABLES_PER_PROJECT=120
FLOW_RUNTIME_TTL_MINUTES=60
DISMISS_PACKAGES=0
KEEP_DEMO_ARTIFACTS=0
ALLOW_RUNTIME_SCHEMA=0
SUKI_FRAMEWORK_ROOT=
SUKI_FRAMEWORK_PUBLIC_URL=
SUKI_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=suki_saas
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4
# SQLite only:
DB_PATH=

# Optional runtime DB paths
PROJECT_REGISTRY_DB_PATH=
SECURITY_STATE_DB_PATH=

# -----------------------------------------------------------------------------
# Security/API guardrails
# -----------------------------------------------------------------------------
API_SECURITY_STRICT=1
API_CSRF_ENFORCE=1
ALLOW_INSECURE_WEBHOOKS=0
API_RATE_LIMIT_CHAT_PER_MIN=60
API_RATE_LIMIT_CHANNEL_PER_MIN=120
API_RATE_LIMIT_DEFAULT_PER_MIN=180
OPENAPI_IMPORT_ALLOWED_HOSTS=
ALANUBE_WEBHOOK_SECRET=
ALANUBE_REPLAY_TTL_SEC=86400
RECORDS_READ_SECRET=
RECORDS_READ_TTL_SEC=900
ENFORCEMENT_MODE=
PROMPT_VERSION=
POLICY_PACK_VERSION=

# -----------------------------------------------------------------------------
# LLM router and providers
# -----------------------------------------------------------------------------
LLM_ROUTER_MODE=auto

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-coder-next
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_REFERER=http://localhost
OPENROUTER_TITLE=suki

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-latest
CLAUDE_BASE_URL=https://api.anthropic.com/v1/messages

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions

# LLM quotas/failover/cost
LLM_SESSION_QUOTA_ENABLED=1
LLM_MAX_REQUESTS_PER_SESSION=120
LLM_SESSION_QUOTA_WINDOW_SECONDS=86400
LLM_MAX_REQUESTS_PER_MINUTE=0
LLM_MAX_REQUESTS_PER_MINUTE_OPENROUTER=90
LLM_MAX_REQUESTS_PER_MINUTE_GEMINI=20
LLM_CIRCUIT_TTL_ERROR_SECONDS=120
LLM_CIRCUIT_TTL_JSON_SECONDS=45
LLM_CIRCUIT_TTL_QUOTA_SECONDS=600
LLM_COST_PER_1K_TOKENS_USD=0.0

# LLM smoke
ALLOW_LLM_SMOKE_SKIP=0
LLM_SMOKE_PRIMARY=gemini
LLM_SMOKE_MODE=gemini
LLM_SMOKE_MAX_TOKENS=320
LLM_SMOKE_TENANT_ID=default
LLM_SMOKE_PROJECT_ID=staging_llm_smoke
LLM_GEMINI_SMOKE_CHECK_FALLBACK=1
LLM_GEMINI_SMOKE_MODELS=
LLM_GEMINI_SMOKE_RETRIES=1

# -----------------------------------------------------------------------------
# Channels
# -----------------------------------------------------------------------------
# Telegram
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_TENANT=default
TELEGRAM_DEFAULT_PROJECT=default
TELEGRAM_REPLAY_TTL_SEC=86400

# WhatsApp Cloud
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_DEFAULT_TENANT=default
WHATSAPP_DEFAULT_PROJECT=default
WHATSAPP_WEBHOOK_DRY_RUN=1
WHATSAPP_REPLAY_TTL_SEC=86400

# -----------------------------------------------------------------------------
# Qdrant / AKP / embeddings
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Legacy fallback only; runtime semantico debe resolver coleccion por memory_type.
QDRANT_COLLECTION=suki_akp_default
AGENT_TRAINING_COLLECTION=agent_training
SECTOR_KNOWLEDGE_COLLECTION=sector_knowledge
USER_MEMORY_COLLECTION=user_memory
QDRANT_TIMEOUT_SEC=10
AKP_VERSION=1.0.0
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_OUTPUT_DIMENSIONALITY=768
EMBEDDING_DISTANCE=Cosine
EMBEDDING_TIMEOUT_SEC=20
# 0 = retrieval semantico deshabilitado con telemetry controlada; 1 = retrieval activo.
SEMANTIC_MEMORY_ENABLED=0
SEMANTIC_MEMORY_TOP_K=5
SEMANTIC_MEMORY_MIN_SCORE=0.0
SEMANTIC_MEMORY_MIN_EVIDENCE_CHUNKS=1
SEMANTIC_MEMORY_MAX_CONTEXT_CHUNKS=3

# -----------------------------------------------------------------------------
# Cache/runtime
# -----------------------------------------------------------------------------
CACHE_DRIVER=file
CACHE_DIR=project/storage/cache
CACHE_TTL_SEC=300

# -----------------------------------------------------------------------------
# QA / KPI / stress toggles
# -----------------------------------------------------------------------------
QA_INCLUDE_STRESS=0
QA_INCLUDE_LLM_SMOKE=0
QA_INCLUDE_LLM_GEMINI_SMOKE=0
QA_INCLUDE_KPI_GATE=1
QA_INCLUDE_CHAT_REAL_100=0

KPI_TENANT_ID=default
KPI_PROJECT_ID=suki_erp
KPI_DAYS=1
KPI_MIN_INTENT_ACCURACY=0.90
KPI_MIN_CORRECTION_SUCCESS=0.95
KPI_MIN_UNKNOWN_SUCCESS=0.90
KPI_MAX_FALLBACK_RATE=0.45
KPI_MAX_TOKENS_PER_SESSION=12000
KPI_MAX_COST_PER_SESSION_USD=0.05

CHAT_STRESS_TENANT_ID=default
CHAT_STRESS_PROJECT_ID=default
CHAT_STRESS_MODE=app
CHAT_STRESS_CONCURRENCY=4
CHAT_STRESS_ITERATIONS=40
CHAT_STRESS_P95_MAX_MS=1200
CHAT_STRESS_P99_MAX_MS=2500
CHAT_STRESS_MAX_ERROR_RATE=0.02

CHANNEL_STRESS_TENANT_ID=default
CHANNEL_STRESS_PROJECT_ID=default
CHANNEL_STRESS_CONCURRENCY=4
CHANNEL_STRESS_ITERATIONS=40
CHANNEL_STRESS_P95_MAX_MS=1200
CHANNEL_STRESS_P99_MAX_MS=2500
CHANNEL_STRESS_MAX_ERROR_RATE=0.02

# -----------------------------------------------------------------------------
# Optional local tooling vars
# -----------------------------------------------------------------------------
MYSQLDUMP_BIN=
SKIP_URL_IMAGE_TEST=0
XDEBUG_MODE=
PHPRC=
PHP_INI_SCAN_DIR=
HOME=
HOMEDRIVE=
HOMEPATH=
