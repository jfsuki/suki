{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GridContract",
  "type": "object",
  "required": ["type", "name", "columns"],
  "properties": {
    "type": { "const": "grid" },
    "name": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["create", "edit", "view"]
    },
    "columns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "label", "type"],
        "properties": {
          "name": { "type": "string" },
          "label": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["text", "number", "select"]
          },
          "role": {
            "type": "string",
            "enum": ["input", "calc", "total", "readonly"]
          },
          "visible_in": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["create", "edit", "view"]
            }
          }
        }
      }
    }
  }
}
